# Default: langsung ke Django (disarankan). Restart `npm run dev` setelah mengubah.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Kosongkan untuk pakai path relatif /api lewat proxy Vite (butuh backend di port 8000).
# VITE_API_BASE_URL=

# `true` = seluruh app menampilkan halaman pemeliharaan (kecuali Anda ubah router).
VITE_MAINTENANCE=false
